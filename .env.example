# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# Real environment variables override anything set here.
#
#   cp .env.example .env
#   uv run platform-api

# --- Sending invite emails (SMTP) -------------------------------------------
# With SMTP_HOST unset the platform does NOT send: it logs the invite link
# instead (fine for dev). The invite is still created either way, and the API
# reports per-recipient delivery so a failure is never silent.
#
# Gmail: enable 2-Step Verification on the account, then create an App Password
# (Google Account -> Security -> App passwords) and paste the 16 characters
# below WITHOUT spaces. Your normal account password will not work.
# SMTP_FROM must be the same address as SMTP_USER — Gmail rewrites From to the
# authenticated user anyway.
#
# Gmail is fine for testing but rate-limits and often lands in spam. For real
# candidates use a transactional provider (SES / Postmark / Resend) with a
# verified sending domain.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=you@gmail.com
SMTP_USE_TLS=true

# --- Interviewer auth --------------------------------------------------------
# REQUIRED in production. If unset, an ephemeral per-process secret is generated
# and every token dies on restart.
# JWT_SECRET=generate-a-long-random-string

# --- Agent <-> platform shared secrets ---------------------------------------
# Set BOTH in production, matching the agent's values. Unset = auth disabled.
# ASSESS_API_TOKEN=shared-secret-we-send-to-the-agent
# CALLBACK_TOKEN=shared-secret-the-agent-sends-back

# --- Behind a reverse proxy / load balancer ----------------------------------
# REQUIRED once the API is not exposed directly. Without it every request appears
# to come from the proxy's IP, so all callers share ONE rate-limit bucket and the
# first few exhaust it for everybody. Only turn it on when a proxy you control
# rewrites X-Forwarded-For — it is a client-supplied header otherwise.
# TRUST_PROXY_HEADERS=true

# --- Optional ----------------------------------------------------------------
# Rate limits: requests per RATE_LIMIT_WINDOW_S per client. 0 disables a bucket.
# DRAFT_RATE_LIMIT_MAX guards the only endpoint that spends LLM money.
# RATE_LIMIT_WINDOW_S=60
# LOGIN_RATE_LIMIT_MAX=10
# REGISTER_RATE_LIMIT_MAX=5
# DRAFT_RATE_LIMIT_MAX=10
# SUBMIT_RATE_LIMIT_MAX=20
# RUN_RATE_LIMIT_MAX=60
# DATABASE_URL=sqlite:///./platform.db
# AGENT_BASE_URL=http://127.0.0.1:8000
# PLATFORM_BASE_URL=http://127.0.0.1:9000
# FRONTEND_BASE_URL=http://127.0.0.1:5173
# REGISTRATION_CODE=invite-only-signup-code
